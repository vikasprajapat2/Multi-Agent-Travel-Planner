# Travel AI - Environment Configuration Template
# Copy this file to .env and fill in your actual API keys

# ============================================
# LLM Configuration (Groq)
# ============================================
# Get your API key from: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Available models:
# - llama-3.3-70b-versatile (recommended)
# - llama2-70b-4096
# - gemma-7b-it
LLM_MODEL=llama-3.3-70b-versatile
ORCHESTRATOR_MODEL=llama-3.3-70b-versatile

# ============================================
# Flight API Configuration (AviationStack)
# ============================================
# Get your API key from: https://aviationstack.com
AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here

# ============================================
# Hotel API Configuration (Booking.com via RapidAPI)
# ============================================
# Get your API key from: https://rapidapi.com
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=booking-com15.p.rapidapi.com

# ============================================
# Application Settings
# ============================================
# Use mock data instead of real APIs (for testing)
USE_MOCK_APIS=false

# Default currency for trip budgets
DEFAULT_CURRENCY=INR

# ============================================
# Server Configuration
# ============================================
APP_HOST=0.0.0.0
APP_PORT=8000
